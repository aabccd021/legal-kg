<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000> legal:pasalVersionHasPointSet <http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point> .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/description> legal:textHasTextString "Dalam Undang-Undang ini yang dimaksud dengan:" .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point> legal:pointSetHasDescription <http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/description> .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point> legal:pointSetHasPoint <http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0001> .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0001> legal:pointHasKey "1" .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0001/text> legal:textHasTextString "Cipta Kerja adalah upaya penciptaan kerja melalui usaha kemudahan, perlindungan, dan pemberdayaan koperasi dan usaha mikro, kecil, dan menengah, peningkatan ekosistem investasi dan kemudahan berusaha, dan investasi Pemerintah Pusat dan percepatan proyek strategis nasional." .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0001> legal:pointHasText <http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0001/text> .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point> legal:pointSetHasPoint <http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0002> .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0002> legal:pointHasKey "2" .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0002/text> legal:textHasTextString "Koperasi adalah koperasi sebagaimana dimaksud dalam Undang-Undang tentang Perkoperasian." .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0002> legal:pointHasText <http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0002/text> .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point> legal:pointSetHasPoint <http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0003> .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0003> legal:pointHasKey "3" .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0003/text> legal:textHasTextString "Usaha Mikro, Kecil, dan Menengah yang selanjutnya disingkat UMK-M adalah usaha mikro, usaha kecil, dan usaha menengah sebagaimana dimaksud dalam Undang- Undang tentang Usaha Mikro, Kecil, dan Menengah." .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0003> legal:pointHasText <http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0003/text> .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point> legal:pointSetHasPoint <http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0004> .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0004> legal:pointHasKey "4" .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0004/text> legal:textHasTextString "Perizinan Berusaha adalah legalitas yang diberikan kepada Pelaku Usaha untuk memulai dan menjalankan usaha dan/atau kegiatannya." .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0004> legal:pointHasText <http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0004/text> .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point> legal:pointSetHasPoint <http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0005> .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0005> legal:pointHasKey "5" .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0005/text> legal:textHasTextString "Pemerintah Pusat adalah Presiden Republik Indonesia yang memegang kekuasaan pemerintahan negara Republik Indonesia yang dibantu oleh Wakil Presiden dan menteri sebagaimana dimaksud dalam Undang-Undang Dasar Negara Republik Indonesia Tahun 1945." .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0005> legal:pointHasText <http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0005/text> .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point> legal:pointSetHasPoint <http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0006> .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0006> legal:pointHasKey "6" .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0006/text> legal:textHasTextString "Pemerintahan Daerah adalah penyelenggaraan urusan pemerintahan oleh Pemerintah Daerah dan dewan perwakilan rakyat daerah menurut asas otonomi dan tugas pembantuan dengan prinsip otonomi seluas-luasnya dalam sistem dan prinsip Negara Kesatuan Republik Indonesia sebagaimana dimaksud dalam Undang-Undang Dasar Negara Republik Indonesia Tahun 1945." .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0006> legal:pointHasText <http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0006/text> .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point> legal:pointSetHasPoint <http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0007> .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0007> legal:pointHasKey "7" .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0007/text> legal:textHasTextString "Pemerintah Daerah adalah kepala daerah sebagai unsur penyelenggara Pemerintahan Daerah yang memimpin pelaksanaan urusan pemerintahan yang menjadi kewenangan daerah otonom." .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0007> legal:pointHasText <http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0007/text> .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point> legal:pointSetHasPoint <http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0008> .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0008> legal:pointHasKey "8" .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0008/text> legal:textHasTextString "Pelaku Usaha adalah orang perseorangan atau badan usaha yang melakukan usaha dan/atau kegiatan pada bidang tertentu." .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0008> legal:pointHasText <http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0008/text> .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point> legal:pointSetHasPoint <http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0009> .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0009> legal:pointHasKey "9" .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0009/text> legal:textHasTextString "Badan Usaha adalah badan usaha berbentuk badan hukum atau tidak berbentuk badan hukum yang didirikan di wilayah Negara Kesatuan Republik Indonesia dan melakukan usaha dan/atau kegiatan pada bidang tertentu." .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0009> legal:pointHasText <http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0009/text> .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point> legal:pointSetHasPoint <http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0010> .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0010> legal:pointHasKey "10" .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0010/text> legal:textHasTextString "Rencana Detail Tata Ruang yang selanjutnya disingkat RDTR adalah rencana secara terperinci tentang tata ruang wilayah kabupaten/kota yang dilengkapi dengan peraturan zonasi kabupaten/kota." .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0010> legal:pointHasText <http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0010/text> .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point> legal:pointSetHasPoint <http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0011> .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0011> legal:pointHasKey "11" .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0011/text> legal:textHasTextString "Persetujuan Bangunan Gedung adalah perizinan yang diberikan kepada pemilik bangunan gedung untuk membangun baru, mengubah, memperluas, mengurangi, dan/atau merawat bangunan gedung sesuai dengan standar teknis Bangunan Gedung." .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0011> legal:pointHasText <http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0011/text> .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point> legal:pointSetHasPoint <http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0012> .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0012> legal:pointHasKey "12" .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0012/text> legal:textHasTextString "Hari adalah hari kerja sesuai dengan yang ditetapkan oleh Pemerintah Pusat." .
<http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0012> legal:pointHasText <http://example.org/legal/document/uu/2020/11/pasal/0001/version/0000000000/point/0012/text> .
