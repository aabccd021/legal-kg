<http://example.org/legal/document/uu/2020/11/pasal/0140/version/0000000000> legal:pasalVersionHasCreatedTimeEpoch 0 .
<http://example.org/legal/document/uu/2020/11/pasal/0140/version/0000000000> legal:pasalVersionHasAyatSet <http://example.org/legal/document/uu/2020/11/pasal/0140/version/0000000000/ayat> .
<http://example.org/legal/document/uu/2020/11/pasal/0140/version/0000000000/ayat> legal:ayatSetHasAyat <http://example.org/legal/document/uu/2020/11/pasal/0140/version/0000000000/ayat/0001> .
<http://example.org/legal/document/uu/2020/11/pasal/0140/version/0000000000/ayat/0001> legal:ayatHasKey 1 .
<http://example.org/legal/document/uu/2020/11/pasal/0140/version/0000000000/ayat/0001/text> legal:textHasTextString "Dalam hal bagian bidang tanah hak pengelolaan diberikan dengan hak milik, bagian bidang tanah hak pengelolaan tersebut hapus dengan sendirinya." .
<http://example.org/legal/document/uu/2020/11/pasal/0140/version/0000000000/ayat/0001> legal:ayatHasText <http://example.org/legal/document/uu/2020/11/pasal/0140/version/0000000000/ayat/0001/text> .
<http://example.org/legal/document/uu/2020/11/pasal/0140/version/0000000000/ayat> legal:ayatSetHasAyat <http://example.org/legal/document/uu/2020/11/pasal/0140/version/0000000000/ayat/0002> .
<http://example.org/legal/document/uu/2020/11/pasal/0140/version/0000000000/ayat/0002> legal:ayatHasKey 2 .
<http://example.org/legal/document/uu/2020/11/pasal/0140/version/0000000000/ayat/0002/text> legal:textHasTextString "Hak milik sebagaimana dimaksud pada ayat (1) hanya diberikan untuk keperluan rumah umum dan keperluan transmigrasi." .
<http://example.org/legal/document/uu/2020/11/pasal/0140/version/0000000000/ayat/0002> legal:ayatHasText <http://example.org/legal/document/uu/2020/11/pasal/0140/version/0000000000/ayat/0002/text> .
<http://example.org/legal/document/uu/2020/11/bab/0008/bagian/0004/paragraf/0002/pasals> legal:pasalSetHasPasal <http://example.org/legal/document/uu/2020/11/pasal/0141> .
<http://example.org/legal/document/uu/2020/11/pasal/0141> legal:pasalHasKey 141 .
<http://example.org/legal/document/uu/2020/11/pasal/0141> legal:pasalHasPasalVersion <http://example.org/legal/document/uu/2020/11/pasal/0141/version/0000000000> .
<http://example.org/legal/document/uu/2020/11> legal:documentHasPasal <http://example.org/legal/document/uu/2020/11/pasal/0141> .
<http://example.org/legal/document/uu/2020/11/pasal/0141/version/0000000000> legal:pasalVersionHasState "exists" .
<http://example.org/legal/document/uu/2020/11/pasal/0141/version/0000000000> legal:pasalVersionHasCreatedTimeEpoch 0 .
<http://example.org/legal/document/uu/2020/11/pasal/0141/version/0000000000/text> legal:textHasTextString "Dalam rangka pengendalian pemanfaatan hak atas tanah di atas hak pengelolaan, dalam waktu tertentu, dilakukan evaluasi pemanfaatan hak atas tanah." .
<http://example.org/legal/document/uu/2020/11/pasal/0141/version/0000000000> legal:pasalVersionHasText <http://example.org/legal/document/uu/2020/11/pasal/0141/version/0000000000/text> .
<http://example.org/legal/document/uu/2020/11/bab/0008/bagian/0004/paragraf/0002/pasals> legal:pasalSetHasPasal <http://example.org/legal/document/uu/2020/11/pasal/0142> .
<http://example.org/legal/document/uu/2020/11/pasal/0142> legal:pasalHasKey 142 .
<http://example.org/legal/document/uu/2020/11/pasal/0142> legal:pasalHasPasalVersion <http://example.org/legal/document/uu/2020/11/pasal/0142/version/0000000000> .
<http://example.org/legal/document/uu/2020/11> legal:documentHasPasal <http://example.org/legal/document/uu/2020/11/pasal/0142> .
<http://example.org/legal/document/uu/2020/11/pasal/0142/version/0000000000> legal:pasalVersionHasState "exists" .
<http://example.org/legal/document/uu/2020/11/pasal/0142/version/0000000000> legal:pasalVersionHasCreatedTimeEpoch 0 .
<http://example.org/legal/document/uu/2020/11/pasal/0142/version/0000000000/text> legal:textHasTextString "Ketentuan lebih lanjut mengenai hak pengelolaan diatur dalam Peraturan Pemerintah." .
<http://example.org/legal/document/uu/2020/11/pasal/0142/version/0000000000> legal:pasalVersionHasText <http://example.org/legal/document/uu/2020/11/pasal/0142/version/0000000000/text> .
<http://example.org/legal/document/uu/2020/11/bab/0008/bagian/0004/paragraf> legal:paragrafSetHasParagraf <http://example.org/legal/document/uu/2020/11/bab/0008/bagian/0004/paragraf/0003> .
<http://example.org/legal/document/uu/2020/11/bab/0008/bagian/0004/paragraf/0003> legal:paragrafHasKey 3 .
<http://example.org/legal/document/uu/2020/11/bab/0008/bagian/0004/paragraf/0003> legal:paragrafHasTitle "Paragraf 3 Satuan Rumah Susun untuk Orang Asing" .
<http://example.org/legal/document/uu/2020/11/bab/0008/bagian/0004/paragraf/0003> legal:paragrafHasPasalSet <http://example.org/legal/document/uu/2020/11/bab/0008/bagian/0004/paragraf/0003/pasals> .
<http://example.org/legal/document/uu/2020/11/bab/0008/bagian/0004/paragraf/0003/pasals> legal:pasalSetHasPasal <http://example.org/legal/document/uu/2020/11/pasal/0143> .
<http://example.org/legal/document/uu/2020/11/pasal/0143> legal:pasalHasKey 143 .
<http://example.org/legal/document/uu/2020/11/pasal/0143> legal:pasalHasPasalVersion <http://example.org/legal/document/uu/2020/11/pasal/0143/version/0000000000> .
<http://example.org/legal/document/uu/2020/11> legal:documentHasPasal <http://example.org/legal/document/uu/2020/11/pasal/0143> .
<http://example.org/legal/document/uu/2020/11/pasal/0143/version/0000000000> legal:pasalVersionHasState "exists" .
<http://example.org/legal/document/uu/2020/11/pasal/0143/version/0000000000> legal:pasalVersionHasCreatedTimeEpoch 0 .
<http://example.org/legal/document/uu/2020/11/pasal/0143/version/0000000000/text> legal:textHasTextString "Hak milik atas satuan rumah susun merupakan hak kepemilikan atas satuan rumah susun yang bersifat perseorangan yang terpisah dengan hak bersama atas bagian bersama, benda bersama, dan tanah bersama." .
<http://example.org/legal/document/uu/2020/11/pasal/0143/version/0000000000> legal:pasalVersionHasText <http://example.org/legal/document/uu/2020/11/pasal/0143/version/0000000000/text> .
