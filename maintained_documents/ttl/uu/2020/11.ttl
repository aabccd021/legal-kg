<$http://example.org/legal/document/uu/2020/11/pasal/128/point/a> legal:pointHasKey "a" .
<$http://example.org/legal/document/uu/2020/11/pasal/128/point/a> legal:pointHasText "Anggaran Pendapatan dan Belanja Negara," .
<$http://example.org/legal/document/uu/2020/11/pasal/128> legal:pointsHasPoint <$http://example.org/legal/document/uu/2020/11/pasal/128/point/b> .
<$http://example.org/legal/document/uu/2020/11/pasal/128/point/b> legal:pointHasKey "b" .
<$http://example.org/legal/document/uu/2020/11/pasal/128/point/b> legal:pointHasText "Pendapatan sendiri," .
