{
  "name": "legal-kg",
  "version": "1.0.0",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "lint": "eslint '**/*.ts'",
    "lint:fix": "eslint --fix '**/*.ts'",
    "cli": "ts-node src/cli.ts",
    "convert": "ts-node src/command/convert/pdf_data_to_json/mod.ts > temp_pdf_data_to_json && ts-node src/command/convert/json_to_md.ts > temp_json_to_md  && ts-node src/command/convert/json-to-ttl/mod.ts > temp_json_to_ttl",
    "query": "yarn cli query > temp_query",
    "generate-ttl": "ts-node src/command/convert/json-to-ttl/mod.ts > temp_json_to_ttl",
    "ocr": "ocrmypdf -l ind --force-ocr --jobs 4 --tesseract-config tesseract-config.cfg",
    "generate:span": "ts-node src/pdf_to_span",
    "generate:data": "ts-node src/span_to_data",
    "generate:md": "ts-node src/data_to_md",
    "generate:ttl": "ts-node src/data_to_ttl",
    "test:types": "tsc --noEmit"
  },
  "engines": {
    "node": "15.6.0"
  },
  "engineStrict": true,
  "eslintConfig": {
    "env": {
      "es2021": true,
      "node": true
    },
    "parser": "@typescript-eslint/parser",
    "parserOptions": {
      "sourceType": "module"
    },
    "plugins": [
      "@typescript-eslint",
      "unused-imports"
    ],
    "extends": [
      "eslint:recommended",
      "plugin:@typescript-eslint/eslint-recommended",
      "plugin:@typescript-eslint/recommended",
      "plugin:prettier/recommended",
      "prettier/@typescript-eslint"
    ],
    "rules": {
      "max-len": [
        "error",
        {
          "code": 100,
          "comments": 100
        }
      ],
      "prettier/prettier": [
        "warn",
        {
          "singleQuote": true,
          "printWidth": 100
        }
      ],
      "@typescript-eslint/no-unused-vars": "off",
      "unused-imports/no-unused-imports-ts": "warn",
      "unused-imports/no-unused-vars-ts": [
        "warn",
        {
          "vars": "all",
          "varsIgnorePattern": "^_",
          "args": "after-used",
          "argsIgnorePattern": "^_"
        }
      ]
    }
  },
  "devDependencies": {
    "@comunica/actor-init-sparql-file": "^1.19.0",
    "@types/js-yaml": "^4.0.0",
    "@types/json-stable-stringify": "^1.0.32",
    "@types/lodash": "^4.14.167",
    "@types/n3": "^1.4.4",
    "@types/node": "^14.14.21",
    "@types/node-fetch": "^2.5.8",
    "@types/roman-numerals": "^0.3.0",
    "@types/striptags": "^3.1.1",
    "@typescript-eslint/eslint-plugin": "^4.22.1",
    "@typescript-eslint/parser": "^4.22.1",
    "assert-never": "^1.2.1",
    "eslint": "^7.25.0",
    "eslint-config-prettier": "^7.1.0",
    "eslint-plugin-lodash": "^7.1.0",
    "eslint-plugin-prettier": "^3.3.1",
    "eslint-plugin-unused-imports": "^1.0.1",
    "json-stable-stringify": "^1.0.1",
    "lodash": "^4.17.20",
    "n3": "^1.8.0",
    "node-fetch": "^2.6.1",
    "pdf.js-extract": "^0.1.5",
    "prettier": "^2.2.1",
    "rimraf": "^3.0.2",
    "roman-numerals": "^0.3.2",
    "ts-node": "^9.1.1",
    "typescript": "^4.2.2"
  },
  "dependencies": {
    "@types/p-timeout": "^1.2.2",
    "@types/yargs": "^16.0.0",
    "add": "^2.0.6",
    "io-ts": "^2.2.16",
    "js-yaml": "^4.0.0",
    "p-timeout": "^4.1.0",
    "striptags": "^3.1.1",
    "tabletojson": "^2.0.4",
    "yargs": "^16.2.0",
    "yarn": "^1.22.10"
  }
}
